# Claude API — usado para el motor de conversación del agente de leads
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# WhatsApp Business Platform (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# Número de WhatsApp de María José (formato internacional, solo dígitos, ej. 573001234567)
# Se usa para detectar sus respuestas de reagendamiento y para notificarle cada lead agendado.
MARIA_JOSE_WHATSAPP_NUMBER=

# Instagram Direct (mismo Meta App que WhatsApp — Messenger Platform para Instagram)
# INSTAGRAM_ACCOUNT_ID: el ID que usa la Graph API para enviar mensajes desde @akanto.estudio
# (puede ser el ID de la cuenta profesional de Instagram o el de la Página vinculada — se
# confirma probando en vivo). El webhook usa el mismo META_APP_SECRET que WhatsApp.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_VERIFY_TOKEN=

# Google Calendar / Sheets — cuenta de servicio
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64 = el JSON de la cuenta de servicio, codificado en base64
# (evita problemas con saltos de línea de la private_key al pegarlo como variable de entorno)
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
GOOGLE_CALENDAR_ID=
GOOGLE_SHEET_ID=

# Token simple para proteger el endpoint de pruebas /leads-agent/simulate
LEADS_AGENT_SIMULATE_TOKEN=

# Token para proteger el panel de administración (/leads-agent/admin) — donde un humano
# puede ver conversaciones y responder manualmente por WhatsApp.
ADMIN_TOKEN=
